# Base URL of the CausalCast FastAPI backend (backend/api/main.py).
# Copy this file to .env and adjust if the backend isn't on the default
# local port. Vite only exposes variables prefixed with VITE_ to the client.
#
#   pip install -r backend/requirements-backend.txt
#   uvicorn backend.api.main:app --reload --port 8000
VITE_API_BASE_URL=http://localhost:8000
