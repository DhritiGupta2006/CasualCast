# CausalCast live backend -- environment variables.
#
# Copy this file to backend/.env (untracked; never commit real keys) or
# export these in your shell before starting the FastAPI app.
#
#   uvicorn backend.api.main:app --reload --port 8000
#
# ANTHROPIC_API_KEY is the only variable that matters for the LLM
# narration layer (backend/llm/). If it's unset, POST /api/insights still
# works exactly as before -- it just returns the deterministic
# template_summary instead of LLM-narrated prose, and reports
# narration_source: "template" instead of "llm". None of the numeric
# parts of the demo (forecast, budget simulator, incrementality figure)
# depend on this key being set.

ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional -- which model narrates the insight panel. Defaults to
# claude-sonnet-5 if unset.
ANTHROPIC_MODEL=claude-sonnet-5
